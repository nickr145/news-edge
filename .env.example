APP_NAME=NewsEdge
ENVIRONMENT=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local default uses sqlite for zero-config startup.
DATABASE_URL=sqlite:///./newsedge.db
REDIS_URL=redis://localhost:6379/0

# Uncomment for Postgres in docker-compose:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/newsedge

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_NEWS_WS_URL=wss://stream.data.alpaca.markets/v2/news
ALPACA_REST_URL=https://data.alpaca.markets/v2
ALPACA_DATA_FEED=iex
DEFAULT_NEWS_TICKERS=AAPL,MSFT,NVDA,TSLA
ENABLE_WEB_BACKFILL=true
WEB_BACKFILL_SOURCES=reuters.com,cnbc.com,finance.yahoo.com,marketwatch.com,fool.com,investopedia.com,barrons.com

SENTIMENT_MODEL=vader
PREDICTION_HORIZON_DAYS=5
MODEL_ARTIFACT_PATH=./artifacts/xgb_recommendation.joblib
PREDICTION_MIN_SAMPLES=30
REDIS_NEWS_STREAM=news_stream
REDIS_CONSUMER_GROUP=news_ingestors
EXCLUDE_MOCK_NEWS=true
SOURCE_WEIGHT_OVERRIDES=reuters:1.25,bloomberg:1.25,cnbc:1.1,benzinga:0.95,mock:0.1

FINNHUB_API_KEY=
NEWSAPI_KEY=